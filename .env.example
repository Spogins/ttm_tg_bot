# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Claude (Anthropic) ─────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ─── AssemblyAI (транскрипция аудио) ────────────────────────
ASSEMBLYAI_API_KEY=

# ─── MongoDB ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=ttm_bot

# ─── Qdrant (векторная БД) ──────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Embeddings (Voyage AI — бесплатно 200M токенов) ───────
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-code-3

# ─── Webhook ────────────────────────────────────────────────
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# ─── Лимиты токенов на пользователя ─────────────────────────
DAILY_TOKEN_LIMIT=30000
MONTHLY_TOKEN_LIMIT=500000
